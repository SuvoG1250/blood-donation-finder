# Copy to .env.local and fill in real values (never commit .env.local).

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY
# Optional: some Supabase dashboards label the anon key as publishable
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY

# Server-side API routes (same project; service role is secret)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Public app URL (no trailing slash) — emails, redirects, cron callbacks
APP_URL=http://localhost:3000

# --- Mailjet (required for donor/admin emails on the host running Next.js) ---
MAILJET_API_KEY=
MAILJET_API_SECRET=
MAILJET_FROM_EMAIL=
MAILJET_FROM_NAME=Raktodaan
# Optional Reply-To
MAILJET_REPLY_TO_EMAIL=

# --- Firebase (optional FCM for PWA push) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# --- Web Push VAPID (used by emergency notify + eligibility reminders) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT_EMAIL=admin@example.com

# --- Telegram (emergency alerts + optional donor linking) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_USERNAME=

# --- Cron jobs (POST /api/cron/* with Authorization: Bearer <CRON_SECRET>) ---
CRON_SECRET=

# Optional SLA cron tuning
# EMERGENCY_ESCALATE_OPEN_MINUTES=30
# EMERGENCY_ESCALATE_VERIFY_PENDING_MINUTES=20
# EMERGENCY_SLA_DISABLE_EMAIL_ALERTS=false
# EMERGENCY_SLA_EXTRA_NOTIFY_EMAILS=admin@example.com

# Optional local AI service (translate / spam-check / rewrite)
AI_SERVICE_URL=
